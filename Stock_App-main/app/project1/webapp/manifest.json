{
  "_version": "1.58.0",

  "sap.app": {
    "id": "sap.stocktrading.app",
    "type": "application",
    "title": "SAP Stock Trading",
    "description": "Real-time Stock Trading on SAP BTP",

    "applicationVersion": {
      "version": "1.0.0"
    },

    "dataSources": {

      "StockAPI": {

        "uri": "/api/",

        "type": "OData",

        "settings": {
          "odataVersion": "4.0"
        }

      }

    }

  },

  "sap.ui": {

    "technology": "UI5",

    "deviceTypes": {

      "desktop": true,

      "tablet": true,

      "phone": true

    }

  },

  "sap.ui5": {

    "rootView": {

      "viewName": "sap.stocktrading.app.view.App",

      "type": "XML",

      "async": true,

      "id": "appView"

    },

    "dependencies": {

      "minUI5Version": "1.120.0",

      "libs": {

        "sap.m": {},

        "sap.ui.core": {},

        "sap.f": {},

        "sap.ui.layout": {},

        "sap.ui.table": {},

        "sap.viz": {}

      }

    },

    "models": {

      "": {

        "dataSource": "StockAPI",

        "preload": true,

        "settings": {

          "synchronizationMode": "None",

          "operationMode": "Server",

          "autoExpandSelect": true

        }

      },

      "i18n": {

        "type": "sap.ui.model.resource.ResourceModel",

        "settings": {

          "bundleName": "sap.stocktrading.app.i18n.i18n"

        }

      }

    },

    "resources": {

      "css": [

        {

          "uri": "css/style.css"

        }

      ]

    },

    "routing": {

      "config": {

        "routerClass": "sap.m.routing.Router",

        "viewType": "XML",

        "viewPath": "sap.stocktrading.app.view",

        "controlId": "appNav",

        "controlAggregation": "pages",

        "async": true

      },

      "routes": [

        { "name": "home",         "pattern": "",                      "target": "home" },
        { "name": "admin",        "pattern": "admin",                  "target": "admin" },
        { "name": "customer",     "pattern": "customer",               "target": "customer" },
        { "name": "portfolio",    "pattern": "portfolio",              "target": "portfolio" },
        { "name": "createStock",  "pattern": "admin/create-stock",     "target": "createStock" },
        { "name": "manageStocks", "pattern": "admin/manage-stocks",    "target": "manageStocks" },
        { "name": "analytics",    "pattern": "admin/analytics",        "target": "analytics" },
        { "name": "priceTrends",  "pattern": "admin/price-trends",     "target": "priceTrends" }

      ],

      "targets": {
        "home":         { "viewId": "home",         "viewName": "Home",         "viewLevel": 1 },
        "admin":        { "viewId": "admin",        "viewName": "Admin",        "viewLevel": 2 },
        "customer":     { "viewId": "customer",     "viewName": "Customer",     "viewLevel": 2 },
        "portfolio":    { "viewId": "portfolio",    "viewName": "Portfolio",    "viewLevel": 3 },
        "createStock":  { "viewId": "createStock",  "viewName": "CreateStock",  "viewLevel": 3 },
        "manageStocks": { "viewId": "manageStocks", "viewName": "ManageStocks", "viewLevel": 3 },
        "analytics":    { "viewId": "analytics",    "viewName": "Analytics",    "viewLevel": 3 },
        "priceTrends":  { "viewId": "priceTrends",  "viewName": "PriceTrends",  "viewLevel": 3 }
      }

    }

  }

}