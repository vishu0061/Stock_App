<mvc:View
    controllerName="sap.stocktrading.app.controller.Customer"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    displayBlock="true">

    <Page id="customerPage" backgroundDesign="List" class="cdPage">

        <!-- ═══════════════════════════════════════════════════════
             1. TOP NAVIGATION BAR
        ═══════════════════════════════════════════════════════ -->
        <customHeader>
            <Bar
                id="customerNavBar"
                design="Header"
                class="cdNavBar">

                <!-- LEFT -->
                <contentLeft>
                    <HBox alignItems="Center" class="cdLeftSection">

                        <!-- BACK BUTTON -->
                        <Button
                            icon="sap-icon://nav-back"
                            type="Transparent"
                            press=".onNavBack"
                            class="cdNavBackBtn"/>

                        <!-- BRAND -->
                        <HBox alignItems="Center" class="cdNavBrand">

                            <!-- LOGO -->
                            <VBox justifyContent="Center" alignItems="Center" class="cdNavLogoWrap">
                                <core:Icon
                                    src="sap-icon://business-objects-experience"
                                    size="1.4rem"
                                    color="#00ffaa"
                                    class="cdNavLogoIcon"/>
                            </VBox>

                            <!-- TEXT -->
                            <VBox justifyContent="Center" class="cdNavBrandText">
                                <Title text="StockTrade Pro" level="H5" class="cdNavBrandName"/>
                                <Text text="Customer Portal" class="cdNavBrandSub"/>
                            </VBox>

                        </HBox>

                    </HBox>
                </contentLeft>

                <!-- CENTER -->
                <contentMiddle>
                    <HBox justifyContent="Center" width="100%">
                        <SearchField
                            id="stockSearchField"
                            placeholder="Search stocks, companies..."
                            width="100%"
                            search=".onStockSearch"
                            liveChange=".onStockSearch"
                            class="cdNavSearchField"/>
                    </HBox>
                </contentMiddle>

                <!-- RIGHT -->
                <contentRight>
                    <HBox
                        alignItems="Center"
                        justifyContent="End"
                        width="100%"
                        class="cdNavActions">

                        <!-- PORTFOLIO BUTTON -->
                        <Button
                            id="navPortfolioBtn"
                            text="Portfolio"
                            icon="sap-icon://wallet"
                            type="Emphasized"
                            press=".onPortfolioPress"
                            class="cdNavPortfolioBtn"/>

                        <!-- NOTIFICATIONS BELL -->
                        <HBox class="cdBellWrap" alignItems="Center">
                            <Button
                                id="customerBellBtn"
                                icon="sap-icon://bell"
                                type="Transparent"
                                press=".onNotificationsPress"
                                class="cdNavBellBtn"
                                tooltip="Notifications"/>
                            <Text
                                id="notifBadgeText"
                                text="{custVM>/notifications/unreadCount}"
                                visible="{= ${custVM>/notifications/unreadCount} > 0}"
                                class="cdNotifBadgeText"/>
                        </HBox>

                        <!-- CUSTOMER PROFILE BUTTON WITH DROPDOWN ARROW -->
                        <HBox
                            alignItems="Center"
                            class="cdNavProfileBtnWrap">

                            <Button
                                id="customerProfileBtn"
                                icon="sap-icon://customer"
                                text="Customer Profile"
                                type="Transparent"
                                class="cdNavProfileBtn"/>

                            <core:Icon
                                src="sap-icon://slim-arrow-down"
                                size="0.7rem"
                                class="cdNavProfileArrow"
                                press=".onProfileMenuPress"/>

                        </HBox>

                    </HBox>
                </contentRight>

            </Bar>
        </customHeader>

        <!-- ═══════════════════════════════════════════════════════
             PAGE CONTENT
        ═══════════════════════════════════════════════════════ -->
        <VBox class="cdPageContent">

            <!-- ─────────────────────────────────────────────────
                 2. HERO SECTION
            ───────────────────────────────────────────────── -->
            <VBox alignItems="Center" class="cdHero">
                <Title text="Customer Trading Dashboard" level="H2" class="cdHeroTitle"/>
                <Text text="Buy, Sell and Monitor Stocks in Real Time" class="cdHeroSub"/>
                <HBox alignItems="Center" class="cdLiveBadge">
                    <core:Icon src="sap-icon://status-positive" class="cdLiveIcon"/>
                    <Text text="Live Trading Active" class="cdLiveBadgeText"/>
                </HBox>
            </VBox>

            <!-- ─────────────────────────────────────────────────
                 3. SUMMARY CARDS ROW
            ───────────────────────────────────────────────── -->
            <HBox justifyContent="SpaceBetween" wrap="Wrap" class="cdCardsRow">

                <!-- Portfolio Value -->
                <VBox class="cdSummaryCard cdCardPortfolio">
                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="cdCardTop">
                        <VBox class="cdCardIconWrap cdIconGreen">
                            <core:Icon src="sap-icon://wallet" class="cdCardIcon"/>
                        </VBox>
                        <ObjectStatus text="{custVM>/summary/portfolioBadge}" state="{custVM>/summary/portfolioBadgeState}" class="cdCardBadge"/>
                    </HBox>
                    <Title text="{custVM>/summary/portfolioValue}" level="H2" class="cdCardValue"/>
                    <Text text="Total Portfolio Value" class="cdCardLabel"/>
                    <Text text="{custVM>/summary/unrealizedText}" class="cdCardSub"/>
                    <ProgressIndicator
                        percentValue="{custVM>/summary/portfolioProgress}"
                        displayValue=""
                        state="{custVM>/summary/portfolioBadgeState}"
                        class="cdCardProgress"/>
                </VBox>

                <!-- Profit / Loss -->
                <VBox class="cdSummaryCard cdCardProfit">
                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="cdCardTop">
                        <VBox class="cdCardIconWrap cdIconGreen">
                            <core:Icon src="sap-icon://trend-up" class="cdCardIcon"/>
                        </VBox>
                        <ObjectStatus text="{custVM>/summary/profitBadge}" state="{custVM>/summary/profitBadgeState}" class="cdCardBadge"/>
                    </HBox>
                    <Title text="{custVM>/summary/profitLoss}" level="H2" class="cdCardValue cdValueGreen"/>
                    <Text text="Total Profit / Loss" class="cdCardLabel"/>
                    <Text text="{custVM>/summary/profitLossPct} vs amount invested" class="cdCardSub"/>
                    <ProgressIndicator
                        percentValue="{custVM>/summary/profitProgress}"
                        displayValue=""
                        state="{custVM>/summary/profitBadgeState}"
                        class="cdCardProgress"/>
                </VBox>

                <!-- Available Balance -->
                <VBox class="cdSummaryCard cdCardBalance">
                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="cdCardTop">
                        <VBox class="cdCardIconWrap cdIconBlue">
                            <core:Icon src="sap-icon://money-bills" class="cdCardIcon"/>
                        </VBox>
                        <ObjectStatus text="Ready to invest" state="Information" class="cdCardBadge"/>
                    </HBox>
                    <Title text="{custVM>/summary/buyingPower}" level="H2" class="cdCardValue cdValueBlue"/>
                    <Text text="Available Balance" class="cdCardLabel"/>
                    <Text text="Buying power" class="cdCardSub"/>
                    <ProgressIndicator
                        percentValue="{custVM>/summary/buyingPowerProgress}"
                        displayValue=""
                        state="Information"
                        class="cdCardProgress"/>
                </VBox>

                <!-- Total Stocks -->
                <VBox class="cdSummaryCard cdCardStocks">
                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="cdCardTop">
                        <VBox class="cdCardIconWrap cdIconPurple">
                            <core:Icon src="sap-icon://pie-chart" class="cdCardIcon"/>
                        </VBox>
                        <ObjectStatus text="{custVM>/summary/stocksBadge}" state="{custVM>/summary/stocksBadgeState}" class="cdCardBadge"/>
                    </HBox>
                    <Title text="{custVM>/summary/ownedStocks}" level="H2" class="cdCardValue cdValuePurple"/>
                    <Text text="Total Stocks Owned" class="cdCardLabel"/>
                    <Text text="{custVM>/summary/ownedStocksSub}" class="cdCardSub"/>
                    <ProgressIndicator
                        percentValue="{custVM>/summary/ownedStocksProgress}"
                        displayValue=""
                        state="{custVM>/summary/stocksBadgeState}"
                        class="cdCardProgress"/>
                </VBox>

            </HBox>

            <!-- ─────────────────────────────────────────────────
                 4. MAIN CONTENT: TABLE + SIDE PANEL
            ───────────────────────────────────────────────── -->
            <HBox alignItems="Stretch" wrap="Wrap" class="cdMainContent">

                <!-- LEFT: Market Table + Graph -->
                <VBox class="cdLeftPanel">

                    <!-- Live Market Table -->
                    <VBox class="cdCard cdTableCard">
                        <HBox justifyContent="SpaceBetween" alignItems="Center" class="cdCardHeader">
                            <HBox alignItems="Center" class="cdCardTitleRow">
                                <core:Icon src="sap-icon://activity-individual" class="cdSectionIcon cdIconGreen"/>
                                <VBox>
                                    <Title text="Live Market" level="H3" class="cdCardTitle"/>
                                    <Text text="Real-time stock prices and trading" class="cdCardSubtitle"/>
                                </VBox>
                            </HBox>
                            <HBox alignItems="Center" class="cdLivePill">
                                <core:Icon src="sap-icon://status-positive" class="cdPillDot"/>
                                <Text text="Live" class="cdPillText"/>
                            </HBox>
                        </HBox>

                        <Table
                            id="stockTable"
                            items="{path:'/Products', parameters:{ $expand:'category' }}"
                            alternateRowColors="false"
                            showSeparators="Inner"
                            class="cdStockTable">

                            <headerToolbar>
                                <OverflowToolbar class="cdTableToolbar">
                                    <ToolbarSpacer/>
                                </OverflowToolbar>
                            </headerToolbar>

                            <columns>
                                <Column class="cdTableCol" width="34%"><Text text="Company" class="cdColHeader"/></Column>
                                <Column class="cdTableCol" width="14%"><Text text="Price" class="cdColHeader"/></Column>
                                <Column class="cdTableCol" width="11%"><Text text="Qty" class="cdColHeader"/></Column>
                                <Column class="cdTableCol" width="13%"><Text text="Trend" class="cdColHeader"/></Column>
                                <Column class="cdTableCol" width="13%"><Text text="Status" class="cdColHeader"/></Column>
                                <Column class="cdTableCol" width="15%"><Text text="Actions" class="cdColHeader"/></Column>
                            </columns>

                            <items>
                                <ColumnListItem class="cdTableRow" type="Active" press=".onSelectProduct">
                                    <cells>
                                        <HBox alignItems="Center" class="cdCompanyCell">
                                            <VBox class="cdStockAvatar cdAvatarGreen">
                                                <Text text="{= ${productName}.substring(0,1) }" class="cdStockAvatarText"/>
                                            </VBox>
                                            <VBox>
                                                <Text text="{productName}" class="cdStockSymbol"/>
                                                <Text text="{= ${category/name} ? ${category/name} : 'General' }" class="cdStockName"/>
                                            </VBox>
                                        </HBox>
                                        <VBox>
                                            <Text text="{= ${currency} + ' ' + ${price} }" class="cdPrice"/>
                                            <Text text="{= (${previousPrice} !== null &amp;&amp; ${previousPrice} !== undefined &amp;&amp; Number(${previousPrice}) !== 0 &amp;&amp; !isNaN(Number(${previousPrice}))) ? ((Number(${price}) - Number(${previousPrice})) &gt;= 0 ? '+' : '') + (Number(${price}) - Number(${previousPrice})).toFixed(2) : '' }" class="cdPriceChange cdChangeUp"/>
                                        </VBox>
                                        <Text text="{stockQuantity}" class="cdQty"/>
                                        <ObjectStatus text="{trend}" state="{= ${trend} === 'BULL' ? 'Success' : (${trend} === 'BEAR' ? 'Error' : 'Warning') }" class="cdChangeStatus"/>
                                        <ObjectStatus text="{status}" state="{= ${status} === 'ACTIVE' ? 'Success' : (${status} === 'LOW' ? 'Warning' : 'Error') }" class="cdStatusBadge"/>
                                        <HBox class="cdActionBtns" alignItems="Center">
                                            <Button text="Buy" type="Accept" press=".onBuyStock" class="cdBuyBtn"/>
                                            <Button icon="{path: 'ID', formatter: '.formatWatchlistIcon'}" type="Transparent" press=".onToggleWatchlist" class="cdWatchlistBtn" tooltip="Toggle Watchlist"/>
                                        </HBox>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </VBox>

                    <!-- ─────────────────────────────────────────
                         5. SECTOR BASED MOVEMENT ANALYTICS SECTION
                    ───────────────────────────────────────────── -->
                    <VBox class="cdCard cdSectorAnalyticsCard sapUiSmallMarginBottom">
                        <!-- HEADER ROW -->
                        <HBox justifyContent="SpaceBetween" alignItems="Center" class="cdCardHeader">
                            <HBox alignItems="Center" class="cdCardTitleRow">
                                <core:Icon src="sap-icon://business-objects-experience" class="cdSectionIcon cdIconBlue"/>
                                <VBox>
                                    <Title text="SECTOR BASED MOVEMENT" level="H3" class="cdCardTitle"/>
                                    <Text text="Market movement by sector correlation" class="cdCardSubtitle"/>
                                </VBox>
                            </HBox>
                            <SegmentedButton
                                id="sectorTimeRange"
                                selectedKey="{custVM>/sectorRange}"
                                selectionChange=".onSectorRangeChange"
                                class="cdSegmentedBtn">
                                <items>
                                    <SegmentedButtonItem key="1D" text="1D"/>
                                    <SegmentedButtonItem key="1W" text="1W"/>
                                    <SegmentedButtonItem key="1M" text="1M"/>
                                    <SegmentedButtonItem key="3M" text="3M"/>
                                    <SegmentedButtonItem key="1Y" text="1Y"/>
                                </items>
                            </SegmentedButton>
                        </HBox>

                        <!-- GRID: LEFT SECTOR PERFORMANCE & RIGHT MAIN CHART -->
                        <HBox alignItems="Stretch" wrap="Wrap" class="cdSectorGrid sapUiSmallMarginTop">
                            <!-- LEFT PANEL: SECTOR PERFORMANCE -->
                            <VBox class="cdSectorPerformancePanel" width="30%">
                                <Title text="SECTOR PERFORMANCE" level="H4" class="cdSubCardTitle sapUiSmallMarginBottom"/>
                                <List items="{custVM>/filteredSectorList}" showSeparators="None" noDataText="No sector data available" class="cdSectorList">
                                    <CustomListItem class="cdSectorItem">
                                        <HBox justifyContent="SpaceBetween" alignItems="Center" width="100%" class="cdSectorRow">
                                            <HBox alignItems="Center">
                                                <VBox class="cdSectorIconWrap {custVM>iconClass}">
                                                    <core:Icon src="{custVM>icon}" class="cdSectorIconSmall"/>
                                                </VBox>
                                                <VBox class="cdSectorMeta">
                                                    <Text text="{custVM>name}" class="cdSectorNameText {custVM>sectorColorClass}"/>
                                                    <Text text="{custVM>description}" class="cdSectorDescText"/>
                                                </VBox>
                                            </HBox>
                                            <HBox alignItems="Center" class="cdSectorValueRow">
                                                <Text text="{custVM>changeText}" class="{custVM>changeClass} cdSectorPercent"/>
                                                <core:Icon src="{custVM>sparklineIcon}" class="{custVM>changeClass} cdSparklineIcon sapUiTinyMarginBegin"/>
                                            </HBox>
                                        </HBox>
                                    </CustomListItem>
                                </List>
                                <HBox class="cdSectorInfoPill sapUiSmallMarginTop" alignItems="Center">
                                    <core:Icon src="sap-icon://information" class="cdInfoIcon"/>
                                    <Text text="Sector performance shows % change in market value for the selected period." class="cdInfoText"/>
                                </HBox>
                            </VBox>

                            <!-- RIGHT PANEL: SECTOR PERFORMANCE OVER TIME CHART -->
                            <VBox class="cdSectorChartPanel" width="70%">
                                <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                                    <Title text="SECTOR PERFORMANCE OVER TIME" level="H4" class="cdSubCardTitle"/>
                                    <HBox alignItems="Center" gap="10px">
                                        <Button icon="sap-icon://full-screen" type="Transparent" class="cdFullScreenBtn"/>
                                    </HBox>
                                </HBox>

                                <!-- Custom Dynamic Sector Chips Selector (Acts as both Selector and Legend) -->
                                <List 
                                    id="sectorChipsList" 
                                    items="{custVM>/sectorList}" 
                                    mode="None" 
                                    showSeparators="None" 
                                    class="cdSectorChipsList sapUiTinyMarginBottom">
                                    <CustomListItem 
                                        type="Active" 
                                        press=".onSectorTabPress"
                                        class="cdSectorChipItem {= ${custVM>key} === ${custVM>/selectedSectorFilter} ? 'cdSectorChipActive' : '' } {custVM>sectorColorClass}">
                                        <HBox alignItems="Center" class="cdSectorChipContent">
                                            <VBox class="cdSectorChipDot {custVM>dotClass}"/>
                                            <Text text="{custVM>name}" class="cdSectorChipText"/>
                                        </HBox>
                                    </CustomListItem>
                                </List>

                                <viz:VizFrame
                                    id="sectorMovementChart"
                                    width="100%"
                                    height="340px"
                                    vizType="line"
                                    uiConfig="{applicationSet:'fiori'}">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{custVM>/sectorChartData}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition name="Time" value="{custVM>Time}"/>
                                                <viz.data:DimensionDefinition name="Sector" value="{custVM>Sector}"/>
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition name="Performance" value="{custVM>Performance}"/>
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Performance"/>
                                        <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Time"/>
                                        <viz.feeds:FeedItem uid="color" type="Dimension" values="Sector"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </VBox>
                        </HBox>

                        <!-- BOTTOM ROW: MARKET SENTIMENT & SECTOR SUMMARY TABLE -->
                        <HBox alignItems="Stretch" wrap="Wrap" class="cdSectorBottomRow sapUiMediumMarginTop">
                            <!-- MARKET SENTIMENT PANEL -->
                            <VBox class="cdSubCard cdSentimentCard" width="45%">
                                <Title text="MARKET SENTIMENT" level="H4" class="cdSubCardTitle sapUiSmallMarginBottom"/>
                                <HBox alignItems="Center" justifyContent="SpaceAround" class="cdSentimentContent">
                                    <!-- Sentiment Gauge Mock Visual -->
                                    <VBox alignItems="Center" class="cdSentimentGaugeBox">
                                        <VBox class="cdSentimentGaugeRadial">
                                            <Text text="{custVM>/sentiment/score}/100" class="cdSentimentScoreText"/>
                                            <Text text="{custVM>/sentiment/text}" class="cdSentimentLabelText {custVM>/sentiment/textClass}"/>
                                        </VBox>
                                        <Text text="{custVM>/sentiment/sentimentTrendMsg}" class="cdSentimentMsgText {custVM>/sentiment/textClass} sapUiTinyMarginTop"/>
                                    </VBox>
                                    <!-- Advancing / Declining Metrics -->
                                    <VBox class="cdSentimentMetricsBox">
                                        <HBox class="cdMetricItem" alignItems="Center">
                                            <core:Icon src="sap-icon://trend-up" class="cdMetricIconGreen"/>
                                            <VBox class="cdMetricTextWrap">
                                                <Text text="Advancing Sectors" class="cdMetricLabel"/>
                                                <Text text="{custVM>/sentiment/advancing}/{custVM>/sentiment/totalSectors}" class="cdMetricValue cdValueGreen"/>
                                            </VBox>
                                        </HBox>
                                        <HBox class="cdMetricItem sapUiSmallMarginTop" alignItems="Center">
                                            <core:Icon src="sap-icon://trend-down" class="cdMetricIconRed"/>
                                            <VBox class="cdMetricTextWrap">
                                                <Text text="Declining Sectors" class="cdMetricLabel"/>
                                                <Text text="{custVM>/sentiment/declining}/{custVM>/sentiment/totalSectors}" class="cdMetricValue cdValueRed"/>
                                            </VBox>
                                        </HBox>
                                        <HBox class="cdMetricItem sapUiSmallMarginTop" alignItems="Center">
                                            <core:Icon src="sap-icon://minus" class="cdMetricIconGrey"/>
                                            <VBox class="cdMetricTextWrap">
                                                <Text text="Unchanged Sectors" class="cdMetricLabel"/>
                                                <Text text="{custVM>/sentiment/unchanged}/{custVM>/sentiment/totalSectors}" class="cdMetricValue cdValueGrey"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>
                                </HBox>
                            </VBox>

                            <!-- SECTOR SUMMARY TABLE -->
                            <VBox class="cdSubCard cdSectorSummaryCard" width="55%">
                                <Title text="SECTOR SUMMARY" level="H4" class="cdSubCardTitle sapUiSmallMarginBottom"/>
                                <Table items="{custVM>/filteredSectorList}" showSeparators="Inner" class="cdSectorSummaryTable">
                                    <columns>
                                        <Column class="cdTableCol" width="40%"><Text text="Sector" class="cdColHeader"/></Column>
                                        <Column class="cdTableCol" width="25%"><Text text="Daily Change" class="cdColHeader"/></Column>
                                        <Column class="cdTableCol" width="20%"><Text text="Trend" class="cdColHeader"/></Column>
                                        <Column class="cdTableCol" width="15%"><Text text="Status" class="cdColHeader"/></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem class="cdTableRow" type="Inactive">
                                            <cells>
                                                <Text text="{custVM>name}" class="cdSectorSummaryName {custVM>sectorColorClass}"/>
                                                <Text text="{custVM>changeText}" class="{custVM>changeClass} cdSectorSummaryChange"/>
                                                <core:Icon src="{custVM>sparklineIcon}" class="{custVM>changeClass} cdSparklineIconSummary"/>
                                                <ObjectStatus text="{custVM>status}" state="{custVM>statusState}" class="cdStatusBadge"/>
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </VBox>
                        </HBox>
                    </VBox>

                </VBox>

                <!-- RIGHT: Portfolio Side Panel -->
                <VBox class="cdRightPanel">

                    <!-- ─────────────────────────────────────────
                         WATCHLIST SECTION
                    ───────────────────────────────────────────── -->
                    <VBox class="cdCard cdHoldingsCard sapUiSmallMarginBottom">
                        <HBox alignItems="Center" class="cdCardHeader">
                            <core:Icon src="sap-icon://favorite" class="cdSectionIcon cdIconAmber"/>
                            <VBox>
                                <Title text="Watchlist" level="H4" class="cdCardTitle"/>
                                <Text text="Your favorite stocks" class="cdCardSubtitle"/>
                            </VBox>
                        </HBox>

                        <List
                            id="watchlistList"
                            items="{custVM>/watchlistData}"
                            showSeparators="None"
                            noDataText="No stocks in watchlist"
                            class="sapUiTinyMarginTop">
                            <CustomListItem class="cdHoldingItem">
                                <HBox justifyContent="SpaceBetween" alignItems="Center" width="100%">
                                    <VBox>
                                        <Text text="{custVM>productName}" class="cdHoldingSymbol"/>
                                        <Text text="{custVM>currency} {custVM>price}" class="cdHoldingShares"/>
                                    </VBox>
                                    <HBox>
                                        <Button text="Buy" type="Accept" press=".onBuyFromWatchlist" class="cdBuyBtn sapUiTinyMarginEnd"/>
                                        <Button icon="sap-icon://decline" type="Transparent" press=".onRemoveWatchlist"/>
                                    </HBox>
                                </HBox>
                            </CustomListItem>
                        </List>
                    </VBox>

                    <!-- ─────────────────────────────────────────
                         6a. HOLDINGS BREAKDOWN (live from getPortfolio)
                    ───────────────────────────────────────────── -->
                    <VBox class="cdCard cdHoldingsCard">
                        <HBox alignItems="Center" class="cdCardHeader">
                            <core:Icon src="sap-icon://pie-chart" class="cdSectionIcon cdIconPurple"/>
                            <VBox>
                                <Title text="Portfolio" level="H4" class="cdCardTitle"/>
                                <Text text="Holdings breakdown" class="cdCardSubtitle"/>
                            </VBox>
                        </HBox>

                        <List
                            id="holdingsList"
                            items="{custVM>/holdings}"
                            showSeparators="None"
                            noDataText="No holdings yet. Buy some stocks to get started."
                            class="sapUiTinyMarginTop">
                            <CustomListItem class="cdHoldingItem">
                                <VBox>
                                    <HBox justifyContent="SpaceBetween" alignItems="Center">
                                        <VBox>
                                            <Text text="{custVM>productName}" class="cdHoldingSymbol"/>
                                            <Text text="{custVM>quantity} shares @ avg ₹{custVM>avgBuyPrice}" class="cdHoldingShares"/>
                                        </VBox>
                                        <ObjectStatus text="{custVM>profitLossPct}" state="{custVM>plState}"/>
                                    </HBox>
                                    <HBox justifyContent="SpaceBetween">
                                        <Text text="{custVM>quantity} shares" class="cdHoldingShares"/>
                                        <Text text="{custVM>currSymbol}{custVM>totalValue}" class="cdHoldingValue"/>
                                    </HBox>
                                    <ProgressIndicator percentValue="{custVM>barValue}" displayValue="" state="{custVM>barState}" class="cdHoldingBar"/>
                                    <Text text="{custVM>profitLoss}" class="{custVM>gainClass}"/>
                                </VBox>
                            </CustomListItem>
                        </List>
                    </VBox>



                    <!-- ─────────────────────────────────────────
                         6c. MARKET INSIGHTS
                    ───────────────────────────────────────────── -->
                    <VBox class="cdCard cdInsightsCard">
                        <HBox alignItems="Center" class="cdCardHeader">
                            <core:Icon src="sap-icon://lightbulb" class="cdSectionIcon cdIconAmber"/>
                            <VBox>
                                <Title text="Market Insights" level="H4" class="cdCardTitle"/>
                                <Text text="AI-powered signals" class="cdCardSubtitle"/>
                            </VBox>
                        </HBox>

                        <VBox items="{custVM>/marketInsights}">
                            <VBox class="cdInsightItem {custVM>itemClass}">
                                <HBox justifyContent="SpaceBetween" alignItems="Center">
                                    <Text text="{custVM>name}" class="cdInsightTitle"/>
                                    <ObjectStatus text="{custVM>status}" state="{custVM>state}"/>
                                </HBox>
                                <Text text="{custVM>desc}" class="cdInsightDesc"/>
                                <ProgressIndicator percentValue="{custVM>score}" displayValue="" state="{custVM>state}" class="cdInsightBar"/>
                            </VBox>
                        </VBox>
                    </VBox>

                </VBox>
            </HBox>
