<mvc:View
    controllerName="sap.stocktrading.app.controller.AdminDashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
xmlns:unified="sap.ui.unified"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:data="sap.viz.ui5.data"
    displayBlock="true">

    <Page
        id="adminDashboardPage"
        showHeader="false"
        enableScrolling="true"
        class="adminDashboardPage">

        <content>

            <!-- ── TOP NAVBAR ─────────────────────────────────────── -->
            <HBox justifyContent="SpaceBetween" alignItems="Center" class="adminNavbar">

                <HBox alignItems="Center">
                    <VBox class="adminLogoBox" justifyContent="Center" alignItems="Center">
                        <core:Icon src="sap-icon://trend-up" size="1.3rem" color="white"/>
                    </VBox>
                    <Title text="SAP STOCK TRADING APP" class="adminNavBrand" wrapping="false"/>
                </HBox>

                <HBox alignItems="Center">
                    <!-- NOTIFICATIONS BELL -->
                    <HBox class="cdBellWrap" alignItems="Center" style="margin-right: 0.6rem;">
                        <Button
                            id="adminBellBtn"
                            icon="sap-icon://bell"
                            type="Transparent"
                            press=".onAdminNotificationsPress"
                            class="adminBellBtn"
                            tooltip="Notifications"/>
                        <Text
                            id="adminNotifBadgeText"
                            text="{adminVM>/notifications/unreadCount}"
                            visible="{= ${adminVM>/notifications/unreadCount} > 0}"
                            class="cdNotifBadgeText"/>
                    </HBox>

                    <MenuButton
                        text="Admin Profile"
                        icon="sap-icon://customer"
                        type="Transparent"
                        class="adminProfileMenuBtn">

                        <menu>

                            <Menu>

                                <MenuItem
                                    text="Profile"
                                    icon="sap-icon://employee"/>

                                <MenuItem
                                    text="Settings"
                                    icon="sap-icon://action-settings"/>

                                <MenuItem
                                    text="Logout"
                                    icon="sap-icon://log"
                                    press=".onLogout"/>

                            </Menu>

                        </menu>

                    </MenuButton>
                </HBox>

            </HBox>

            <!-- ── NAV TABS ───────────────────────────────────────── -->
            <HBox class="adminNavTabs" alignItems="Center">
                <Button id="tabManage"    text="📦 Manage"    type="Transparent" class="adminNavTab" press=".onTabStocks"/>
                <Button id="tabAnalytics" text="📊 Analytics" type="Transparent" class="adminNavTab" press=".onTabAnalytics"/>
                <Button id="tabTrends"    text="📈 Trends"    type="Transparent" class="adminNavTab" press=".onTabTrends"/>
                <ToolbarSpacer/>
                
            </HBox>

            <!-- ── MAIN CONTENT ───────────────────────────────────── -->
            <VBox class="adminDashboardContent">

                <!-- WELCOME -->
                <VBox class="adminWelcomeBanner">
                    <Title text="👋 Welcome, Admin" class="adminWelcomeTitle"/>
                    <Text text="Manage stocks, monitor trading activity, and analyze market trends" class="adminWelcomeSubtitle"/>
                </VBox>

                <!-- ── STAT CARDS ─────────────────────────────────── -->
                <HBox class="adminStatsRow" wrap="Wrap">

                    <VBox class="adminStatCard adminStatCardBlue">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://product" size="1.6rem" color="#7c3aed" class="adminStatIcon"/>
                            <VBox class="adminStatTextBlock">
                                <Text text="Total Stocks" class="adminStatLabel"/>
                                <Title id="statTotalStocks" text="0" class="adminStatValue"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox class="adminStatCard adminStatCardGreen">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://cart" size="1.6rem" color="#059669" class="adminStatIcon"/>
                            <VBox class="adminStatTextBlock">
                                <Text text="Total Buys" class="adminStatLabel"/>
                                <Title id="statTotalBuyers" text="0" class="adminStatValue"/>
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox class="adminStatCard adminStatCardOrange">
                        <HBox alignItems="Center">
                            <core:Icon src="sap-icon://sales-order" size="1.6rem" color="#d97706" class="adminStatIcon"/>
                            <VBox class="adminStatTextBlock">
                                <Text text="Total Sells" class="adminStatLabel"/>
                                <Title id="statTotalSellers" text="0" class="adminStatValue"/>
                            </VBox>
                        </HBox>
                    </VBox>

                </HBox>

                <!-- ── QUICK ACTIONS ──────────────────────────────── -->
                <VBox class="adminSectionBlock">
                    <Title text="QUICK ACTIONS" class="adminSectionTitle"/>
                    <HBox wrap="Wrap" class="adminActionsRow">

                        <VBox class="adminActionCard adminActionCardCreate">
                            <core:Icon src="sap-icon://add-product" size="1.8rem" color="#7c3aed" class="adminActionIcon"/>
                            <Title text="Create Stock" class="adminActionLabel"/>
                            <Text text="Add a new stock product" class="adminActionDesc"/>
                            <Button text="Open" type="Transparent" press=".onQuickCreateStock" class="adminActionCardBtn"/>
                        </VBox>

                        <VBox class="adminActionCard adminActionCardManage">
                            <core:Icon src="sap-icon://table-view" size="1.8rem" color="#2563eb" class="adminActionIcon"/>
                            <Title text="Manage Stocks" class="adminActionLabel"/>
                            <Text text="Edit or delete stocks" class="adminActionDesc"/>
                            <Button text="Open" type="Transparent" press=".onQuickManageStocks" class="adminActionCardBtn"/>
                        </VBox>

                        <VBox class="adminActionCard adminActionCardAnalytics">
                            <core:Icon src="sap-icon://bar-chart" size="1.8rem" color="#0891b2" class="adminActionIcon"/>
                            <Title text="View Analytics" class="adminActionLabel"/>
                            <Text text="Track market performance" class="adminActionDesc"/>
                            <Button text="Open" type="Transparent" press=".onQuickViewAnalytics" class="adminActionCardBtn"/>
                        </VBox>

                        <VBox class="adminActionCard adminActionCardTrends">
                            <core:Icon src="sap-icon://line-chart" size="1.8rem" color="#059669" class="adminActionIcon"/>
                            <Title text="Price Trends" class="adminActionLabel"/>
                            <Text text="View live stock trends" class="adminActionDesc"/>
                            <Button text="Open" type="Transparent" press=".onQuickPriceTrends" class="adminActionCardBtn"/>
                        </VBox>

                    </HBox>
                </VBox>

                <!-- ── DAILY TRADE CHART ─────────────────────────────── -->
                <VBox class="adminSectionBlock">
                    <HBox alignItems="Center" class="adminSectionHeaderRow">
                        <core:Icon src="sap-icon://line-chart" size="1.1rem" color="#7c3aed" class="adminSectionIcon"/>
                        <Title text="DAILY BUYS vs SELLS" class="adminSectionTitle"/>
                    </HBox>
                    <VBox class="adminChartContainer">
                        <viz:VizFrame
                            id="dailyTradeChart"
                            vizType="line"
                            width="100%"
                            height="300px"
                            uiConfig="{applicationSet:'fiori'}"
                            class="adminVizFrame">
                            <viz:dataset>
                                <data:FlattenedDataset data="{dashboard>/dailyData}">
                                    <data:dimensions>
                                        <data:DimensionDefinition name="Date" value="{dashboard>date}"/>
                                    </data:dimensions>
                                    <data:measures>
                                        <data:MeasureDefinition name="Buys"  value="{dashboard>buys}"/>
                                        <data:MeasureDefinition name="Sells" value="{dashboard>sells}"/>
                                    </data:measures>
                                </data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <feeds:FeedItem uid="valueAxis"    type="Measure"    values="Buys,Sells"/>
                                <feeds:FeedItem uid="categoryAxis" type="Dimension"  values="Date"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </VBox>
                </VBox>

                <!-- ── RECENT STOCKS TABLE ────────────────────────── -->
                <VBox class="adminSectionBlock">
                    <HBox alignItems="Center" class="adminSectionHeaderRow">
                        <core:Icon src="sap-icon://product" size="1.1rem" color="#7c3aed" class="adminSectionIcon"/>
                        <Title text="RECENTLY CREATED STOCKS" class="adminSectionTitle"/>
                        <ToolbarSpacer/>
                        <Button text="View All Stocks" type="Transparent" class="adminViewAllBtn" press=".onTabStocks"/>
                    </HBox>

                    <Table
                        id="recentStocksTable"
                        inset="false"
                        growing="true"
                        growingThreshold="5"
                        class="adminRecentTable"
                        items="{
                            path: '/Products',
                            parameters: { $expand: 'category' }
                        }">

                        <columns>
                            <Column><Text text="Name"/></Column>
                            <Column><Text text="Category"/></Column>
                            <Column hAlign="End"><Text text="Price"/></Column>
                            <Column hAlign="End"><Text text="Change"/></Column>
                            <Column hAlign="Center"><Text text="Currency"/></Column>
                            <Column hAlign="Center"><Text text="Quantity"/></Column>
                            <Column hAlign="Center"><Text text="Trend"/></Column>
                            <Column hAlign="Center"><Text text="Status"/></Column>
                            <Column hAlign="Center"><Text text="Graph"/></Column>
                        </columns>

                        <items>
                            <ColumnListItem class="adminTableRow" press=".onStockRowPress">
                                <cells>

                                    <Text text="{productName}"/>

                                    <ObjectStatus text="{category/name}" state="Information"/>

                                    <ObjectNumber number="{price}" unit="{currency}"/>

                                    <!-- Change % -->
                                    <ObjectStatus
                                        text="{
                                            parts: ['price', 'previousPrice'],
                                            formatter: '.formatChangePercent'
                                        }"
                                        state="{
                                            parts: ['price', 'previousPrice'],
                                            formatter: '.formatChangeState'
                                        }"/>

                                    <ObjectStatus text="{currency}" state="Information"/>

                                    <!-- FIX: use formatter instead of broken expression binding -->
                                    <ObjectStatus
                                        text="{stockQuantity}"
                                        state="{
                                            path: 'stockQuantity',
                                            formatter: '.formatQtyState'
                                        }"/>

                                    <!-- FIX: use formatter for trend state and icon -->
                                    <ObjectStatus
                                        text="{trend}"
                                        state="{
                                            path: 'trend',
                                            formatter: '.formatTrendState'
                                        }"
                                        icon="{
                                            path: 'trend',
                                            formatter: '.formatTrendIcon'
                                        }"/>

                                    <!-- FIX: use formatter for status state -->
                                    <ObjectStatus
                                        text="{status}"
                                        state="{
                                            path: 'status',
                                            formatter: '.formatStatusState'
                                        }"
                                        icon="sap-icon://inventory"/>

                                    <Button
                                        text="📊 Graph"
                                        type="Transparent"
                                        press=".onViewStockGraph"
                                        class="adminGraphBtn"/>

                                </cells>
                            </ColumnListItem>
                        </items>

                    </Table>
                </VBox>

            </VBox>

            <!-- ── FOOTER ─────────────────────────────────────────── -->
            <HBox class="adminDashboardFooter" justifyContent="Center" alignItems="Center">
                <Text text="© 2026 SAP Stock Trading App — Admin Portal" class="adminFooterText"/>
            </HBox>

        </content>
    </Page>
</mvc:View>